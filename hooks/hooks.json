{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\session-start.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/subagent-start.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\subagent-start.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|PowerShell)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/dep-guard.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\dep-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "^Write$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/file-meter.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\file-meter.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/build-ledger.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\build-ledger.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/mode-toggle.js\"",
            "commandWindows": "node \"$env:CLAUDE_PLUGIN_ROOT\\hooks\\mode-toggle.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
